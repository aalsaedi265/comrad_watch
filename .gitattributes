# Normalize line endings. Store LF in the repo; Git checks out native on Windows.
* text=auto

# Source and config must use LF (CRLF breaks gofmt, shell scripts, and Docker).
*.go        text eol=lf
*.sh        text eol=lf
*.kt        text eol=lf
*.kts       text eol=lf
*.sql       text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.properties text eol=lf
Dockerfile  text eol=lf
Caddyfile   text eol=lf
.env.example text eol=lf
gradlew     text eol=lf

# Windows batch files require CRLF.
*.bat       text eol=crlf

# Binary assets — never normalize.
*.png       binary
*.jpg       binary
*.ico       binary
*.jar       binary
*.exe       binary
*.keystore  binary
