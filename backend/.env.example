# Server
HTTP_PORT=8080
RTMP_PORT=1935

# Database (PostgreSQL)
DATABASE_URL=postgres://comradwatch:password@localhost:5432/comradwatch?sslmode=disable

# JWT Secret (generate a strong random string)
JWT_SECRET=change-me-to-a-random-secret

# Video segment storage directory
SEGMENT_DIR=./segments

# Encryption key for OAuth tokens (32+ chars, generate a strong random string)
ENCRYPTION_KEY=change-me-to-a-random-encryption-key

# Google Drive (Phase 3)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/google/callback

# Instagram (Phase 4)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
